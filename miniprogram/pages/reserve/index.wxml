<view class="page">
  <view wx:if="{{loading}}" class="empty-card">正在加载预订信息...</view>

  <view wx:if="{{merchant}}" class="section-card banner-card">
    <view class="section-kicker">RESERVE</view>
    <view class="banner-title">{{merchant.name}}</view>
    <view class="banner-copy">{{merchant.address}}</view>
    <view class="banner-stats">
      <view class="banner-stat">
        <view class="banner-stat-value">{{form.date}}</view>
        <view class="banner-stat-label">用餐日期</view>
      </view>
      <view class="banner-stat">
        <view class="banner-stat-value">{{form.time}}</view>
        <view class="banner-stat-label">开席时间</view>
      </view>
      <view class="banner-stat">
        <view class="banner-stat-value">{{form.guests}}</view>
        <view class="banner-stat-label">预计人数</view>
      </view>
    </view>
  </view>

  <view wx:if="{{merchant}}" class="form-card">
    <view class="form-title">提交预订</view>
    <view class="form-subtitle">提交后将由商家确认。当前手机号也会用于“我的订单”查询。</view>

    <view class="form-block">
      <view class="section-kicker">CONTACT</view>
      <view class="form-block-title">联系人信息</view>
      <view class="form-field">
        <view class="field-label">联系人</view>
        <input class="field-control" placeholder-class="field-placeholder" placeholder="请输入联系人姓名" data-field="contactName" value="{{form.contactName}}" bindinput="handleInput" />
      </view>
      <view class="form-field">
        <view class="field-label">手机号</view>
        <input class="field-control" type="number" maxlength="11" placeholder-class="field-placeholder" placeholder="用于订单查询和确认通知" data-field="phone" value="{{form.phone}}" bindinput="handleInput" />
      </view>
    </view>

    <view class="form-block">
      <view class="section-kicker">SCHEDULE</view>
      <view class="form-block-title">用餐安排</view>
      <view class="field-row">
        <view class="field-col">
          <view class="field-label">用餐日期</view>
          <picker mode="date" value="{{form.date}}" bindchange="handleDateChange">
            <view class="field-picker">{{form.date}}</view>
          </picker>
        </view>
        <view class="field-col">
          <view class="field-label">开席时间</view>
          <picker mode="time" value="{{form.time}}" bindchange="handleTimeChange">
            <view class="field-picker">{{form.time}}</view>
          </picker>
        </view>
      </view>
      <view class="field-row">
        <view class="field-col">
          <view class="field-label">用餐人数</view>
          <input class="field-control" type="number" placeholder-class="field-placeholder" placeholder="例如 10" data-field="guests" value="{{form.guests}}" bindinput="handleInput" />
        </view>
        <view class="field-col">
          <view class="field-label">预算范围</view>
          <input class="field-control" type="number" placeholder-class="field-placeholder" placeholder="例如 3000" data-field="budget" value="{{form.budget}}" bindinput="handleInput" />
        </view>
      </view>

      <view class="form-field">
        <view class="field-label">宴请类型</view>
        <view class="occasion-row">
          <block wx:for="{{occasions}}" wx:key="*this">
            <view class="toolbar-item {{form.occasion === item ? 'toolbar-item--active' : ''}}" data-value="{{item}}" bindtap="chooseOccasion">
              {{item}}
            </view>
          </block>
        </view>
      </view>

      <view class="form-field">
        <view class="field-label">包间选择</view>
        <picker mode="selector" range="{{roomOptions}}" value="{{roomIndex}}" bindchange="handleRoomChange">
          <view class="field-picker">{{selectedRoomText}}</view>
        </picker>
      </view>
    </view>

    <view class="selected-room-card" wx:if="{{selectedRoom}}">
      <view class="card-head">
        <view>
          <view class="card-title">{{selectedRoom.name}}</view>
          <view class="card-subtitle">{{selectedRoom.recommendedFor}}</view>
        </view>
        <view class="status-pill {{selectedRoom.levelClass}}">{{selectedRoom.availability}}</view>
      </view>
      <view class="pill-row">
        <view class="ghost-pill">{{selectedRoom.capacityMin}}-{{selectedRoom.capacityMax}} 位</view>
        <view class="ghost-pill">¥{{selectedRoom.minSpend}} 起</view>
      </view>
    </view>

    <view class="form-block">
      <view class="section-kicker">DETAILS</view>
      <view class="form-block-title">备注</view>
      <view class="form-field">
        <view class="field-label">补充说明</view>
        <textarea class="field-textarea" placeholder-class="field-placeholder" placeholder="记录忌口、布置、到店时间等要求" data-field="remarks" value="{{form.remarks}}" bindinput="handleInput" />
      </view>
    </view>

    <view class="booking-summary">
      <view class="section-kicker">RECOMMEND</view>
      <view class="section-title">推荐包间</view>
      <block wx:for="{{suitableRooms}}" wx:key="id">
        <view class="room-card {{form.roomId === item.id ? 'room-card--selected' : ''}}" data-room-id="{{item.id}}" bindtap="selectRecommendedRoom">
          <view class="card-head">
            <view>
              <view class="card-title">{{item.name}}</view>
              <view class="card-subtitle">{{item.recommendedFor}}</view>
            </view>
            <view class="status-pill {{item.levelClass}}">{{item.availability}}</view>
          </view>
          <view class="pill-row">
            <view class="ghost-pill">{{item.capacityMin}}-{{item.capacityMax}} 位</view>
            <view class="ghost-pill">¥{{item.minSpend}} 起</view>
          </view>
        </view>
      </block>
    </view>

    <view class="button-row section">
      <button class="primary-button button-flex" bindtap="submitBooking">确认提交预订</button>
    </view>
  </view>
</view>
