<view class="page">
  <!-- 手机号查询 -->
  <view class="search-section">
    <view class="search-section__title">我的订单</view>
    <view class="search-section__hint">输入下单时填写的手机号查询</view>
    <view class="search-bar">
      <input
        class="search-input"
        type="number"
        maxlength="11"
        placeholder-class="field-placeholder"
        placeholder="输入手机号"
        value="{{phone}}"
        bindinput="handlePhone"
        confirm-type="search"
        bindconfirm="searchBookings"
      />
      <button class="search-btn" bindtap="searchBookings">查询</button>
    </view>
  </view>

  <!-- 订单列表 -->
  <view wx:if="{{loading}}" class="empty-card">正在加载订单...</view>

  <block wx:if="{{!loading && bookings.length}}">
    <view class="booking-card" wx:for="{{bookings}}" wx:key="id">
      <view class="booking-card__header">
        <view class="booking-card__title">{{item.merchantName}} · {{item.roomName}}</view>
        <view class="status-pill {{item.statusClass}}">{{item.status}}</view>
      </view>
      <view class="booking-card__detail">
        <text>{{item.date}} {{item.time}}</text>
        <text> · {{item.guests}} 位</text>
      </view>
      <view class="booking-card__detail" wx:if="{{item.occasion}}">
        <text>{{item.occasion}}</text>
      </view>
      <view class="booking-card__contact">联系人：{{item.contactName}}</view>
      <view class="booking-card__actions">
        <button
          class="booking-card__nav-btn"
          data-id="{{item.id}}"
          bindtap="viewBooking"
        >查看详情</button>
        <button
          class="booking-card__nav-btn"
          wx:if="{{item.rawStatus === 'confirmed' || item.rawStatus === 'completed'}}"
          data-id="{{item.id}}"
          bindtap="openInvitation"
        >邀请函</button>
        <button
          class="booking-card__nav-btn"
          wx:if="{{item.merchantLatitude && item.merchantLongitude}}"
          data-latitude="{{item.merchantLatitude}}"
          data-longitude="{{item.merchantLongitude}}"
          data-name="{{item.merchantName}}"
          data-address="{{item.merchantAddress}}"
          bindtap="openLocation"
        >导航到门店</button>
      </view>
    </view>
  </block>

  <view wx:if="{{searched && !loading && !bookings.length}}" class="empty-card">
    没有查到订单，请确认手机号是否正确
  </view>
</view>
