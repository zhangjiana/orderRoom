<view class="page">
  <!-- 顶部定位 + 搜索 -->
  <view class="location-bar">
    <view class="location-text" wx:if="{{cityName}}">{{cityName}}</view>
    <view class="location-text location-text--hint" wx:else>开启定位查看附近餐厅</view>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder-class="field-placeholder"
      placeholder="搜索餐厅名称"
      value="{{keyword}}"
      bindinput="handleKeyword"
      confirm-type="search"
      bindconfirm="searchMerchants"
    />
    <button class="search-btn" bindtap="searchMerchants">搜索</button>
  </view>

  <!-- 商户卡片列表 -->
  <view wx:if="{{loading}}" class="empty-card">正在获取商家...</view>

  <block wx:if="{{!loading && merchants.length}}">
    <view
      class="merchant-card"
      wx:for="{{merchants}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="openMerchant"
    >
      <view class="merchant-card__header">
        <view class="merchant-card__name">{{item.name}}</view>
        <view class="merchant-card__distance" wx:if="{{item.distanceText}}">{{item.distanceText}}</view>
      </view>
      <view class="merchant-card__info">
        <text>{{item.roomSummary}}</text>
        <text class="merchant-card__dot">·</text>
        <text>{{item.businessHours}}</text>
      </view>
      <view class="merchant-card__tags" wx:if="{{item.featuredTags.length}}">
        <view
          class="merchant-card__tag"
          wx:for="{{item.featuredTags}}"
          wx:for-item="tag"
          wx:key="*this"
        >{{tag}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{!loading && !merchants.length}}" class="empty-card">
    暂无符合条件的商家，试试换个关键词
  </view>
</view>
