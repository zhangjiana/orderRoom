.invitation-page {
  background: linear-gradient(180deg, #f5efe7 0%, #efe2d3 100%);
}

.invitation-card {
  min-height: 720rpx;
  padding: 56rpx 40rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(142, 93, 42, 0.22);
  background: #fffaf3;
  box-shadow: 0 24rpx 60rpx rgba(80, 56, 31, 0.12);
  text-align: center;
}

.invite-kicker {
  letter-spacing: 0.24em;
  font-size: 22rpx;
  color: #9c6b36;
}

.invite-title {
  margin-top: 44rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #2b241d;
}

.invite-host {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #6f6052;
}

.invite-divider {
  width: 120rpx;
  height: 2rpx;
  margin: 60rpx auto;
  background: #d9c1a4;
}

.invite-main {
  font-size: 38rpx;
  font-weight: 700;
  color: #2f2b27;
}

.invite-room,
.invite-time,
.invite-address {
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #5e5246;
}

.invite-address {
  color: #8a7b6d;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.action-button {
  flex: 1;
}
