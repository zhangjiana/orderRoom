<view class="page">
  <view wx:if="{{loading}}" class="empty-card">正在加载预订信息...</view>

  <block wx:if="{{merchant}}">
    <!-- 已选包间信息 -->
    <view class="selected-room-info" wx:if="{{selectedRoom}}">
      <view class="selected-room-info__merchant">{{merchant.name}}</view>
      <view class="selected-room-info__room">{{selectedRoom.name}} · {{selectedRoom.capacityMin}}-{{selectedRoom.capacityMax}} 位</view>
      <view class="selected-room-info__price">¥{{selectedRoom.minSpend}} 起</view>
    </view>

    <!-- 预订表单 -->
    <view class="form-card">
      <view class="form-title">提交预订</view>

      <!-- 用餐安排 -->
      <view class="form-block">
        <view class="form-block-title">用餐安排</view>
        <view class="field-row">
          <view class="field-col">
            <view class="field-label">就餐日期</view>
            <picker mode="date" value="{{form.date}}" bindchange="handleDateChange">
              <view class="field-picker">{{form.date}}</view>
            </picker>
          </view>
          <view class="field-col">
            <view class="field-label">就餐时间</view>
            <picker mode="time" value="{{form.time}}" bindchange="handleTimeChange">
              <view class="field-picker">{{form.time}}</view>
            </picker>
          </view>
        </view>
        <view class="field-row">
          <view class="field-col">
            <view class="field-label">用餐人数</view>
            <input class="field-control" type="number" placeholder-class="field-placeholder" placeholder="例如 10" data-field="guests" value="{{form.guests}}" bindinput="handleInput" />
          </view>
          <view class="field-col">
            <view class="field-label">宴请场合</view>
            <picker mode="selector" range="{{occasions}}" value="{{occasionIndex}}" bindchange="handleOccasionChange">
              <view class="field-picker">{{form.occasion}}</view>
            </picker>
          </view>
        </view>
      </view>

      <!-- 联系人信息 -->
      <view class="form-block">
        <view class="form-block-title">联系人</view>
        <view class="form-field">
          <view class="field-label">联系人姓名</view>
          <input class="field-control" placeholder-class="field-placeholder" placeholder="请输入联系人姓名" data-field="contactName" value="{{form.contactName}}" bindinput="handleInput" />
        </view>
        <view class="form-field">
          <view class="field-label">联系电话</view>
          <input class="field-control" type="number" maxlength="11" placeholder-class="field-placeholder" placeholder="用于商家确认预订" data-field="phone" value="{{form.phone}}" bindinput="handleInput" />
        </view>
      </view>

      <!-- 可选信息 -->
      <view class="form-block">
        <view class="form-block-title">其他（选填）</view>
        <view class="form-field">
          <view class="field-label">预算</view>
          <input class="field-control" type="number" placeholder-class="field-placeholder" placeholder="例如 3000" data-field="budget" value="{{form.budget}}" bindinput="handleInput" />
        </view>
        <view class="form-field">
          <view class="field-label">备注</view>
          <textarea class="field-textarea" placeholder-class="field-placeholder" placeholder="忌口、布置、到店时间等" data-field="remarks" value="{{form.remarks}}" bindinput="handleInput" />
        </view>
      </view>

      <view class="submit-section">
        <button class="primary-button" bindtap="submitBooking">确认提交预订</button>
      </view>
    </view>
  </block>
</view>
