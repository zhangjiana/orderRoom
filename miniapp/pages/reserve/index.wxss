.selected-room-info {
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff8ef 0%, #f8efe3 100%);
  border: 1rpx solid rgba(156, 107, 54, 0.15);
  margin-bottom: 24rpx;
}

.selected-room-info__merchant {
  font-size: 26rpx;
  color: #8b7865;
}

.selected-room-info__room {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2c241d;
}

.selected-room-info__price {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #8e5d2a;
  font-weight: 600;
}

.submit-section {
  margin-top: 36rpx;
}
