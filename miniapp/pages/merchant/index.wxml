<view class="page">
  <view wx:if="{{loading}}" class="empty-card">正在加载商家详情...</view>

  <block wx:if="{{merchant}}">
    <!-- 商户信息头 -->
    <view class="merchant-header">
      <view class="merchant-header__name">{{merchant.name}}</view>
      <view class="merchant-header__address">{{merchant.address}}</view>
      <view class="merchant-header__meta">
        <text>{{merchant.businessHours}}</text>
        <text wx:if="{{merchant.distanceText}}"> · {{merchant.distanceText}}</text>
      </view>
      <view class="merchant-header__phone" wx:if="{{merchant.contactPhone}}">
        电话：{{merchant.contactPhone}}
      </view>
      <button class="nav-button" bindtap="openLocation">地图导航</button>
    </view>

    <!-- 包间列表 -->
    <view class="room-list-title">包间列表</view>
    <block wx:for="{{merchant.rooms}}" wx:key="id">
      <view class="room-card" data-room-id="{{item.id}}" bindtap="goReserve">
        <view class="room-card__header">
          <view class="room-card__name">{{item.name}}</view>
          <view class="status-pill {{item.levelClass}}">{{item.availability}}</view>
        </view>
        <view class="room-card__info">
          <text>{{item.capacityMin}}-{{item.capacityMax}} 位</text>
          <text class="room-card__dot">·</text>
          <text>¥{{item.minSpend}} 起</text>
        </view>
        <view class="room-card__tags" wx:if="{{item.features.length}}">
          <view class="room-card__tag" wx:for="{{item.features}}" wx:for-item="feat" wx:key="*this">{{feat}}</view>
        </view>
      </view>
    </block>

    <!-- 地图（底部可展开） -->
    <view class="map-section">
      <view class="map-section__toggle" bindtap="toggleMap">
        {{showMap ? '收起地图' : '查看地图'}}
      </view>
      <view class="map-card" wx:if="{{showMap}}">
        <map
          class="map-view"
          longitude="{{merchant.longitude}}"
          latitude="{{merchant.latitude}}"
          scale="15"
          markers="{{markers}}"
        ></map>
      </view>
    </view>
  </block>
</view>
