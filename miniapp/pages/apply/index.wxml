<view class="page">
  <!-- 提交成功 -->
  <block wx:if="{{submitted}}">
    <view class="section-card">
      <view class="success-icon">✓</view>
      <view class="form-title" style="text-align:center;">申请已提交</view>
      <view class="helper-text" style="text-align:center;margin-top:16rpx;">
        我们会尽快审核你的入驻申请，审核通过后将自动开通商家功能。
      </view>
      <button class="primary-button" style="margin-top:40rpx;" bindtap="goBack">返回</button>
    </view>
  </block>

  <!-- 表单 -->
  <block wx:else>
    <view class="form-card">
      <view class="form-title">商家入驻申请</view>
      <view class="helper-text" style="margin-top:8rpx;">填写以下信息，提交后等待平台审核。</view>

      <!-- 商家信息 -->
      <view class="form-block">
        <view class="form-block-title">商家信息</view>
        <view class="form-field">
          <view class="field-label">商家名称</view>
          <input class="field-control" placeholder-class="field-placeholder" placeholder="如：XX 酒楼" data-field="merchantName" value="{{form.merchantName}}" bindinput="handleInput" />
        </view>
        <view class="form-field">
          <view class="field-label">营业时间</view>
          <picker mode="selector" range="{{businessHoursOptions}}" value="{{businessHoursIndex}}" bindchange="handleBusinessHoursChange">
            <view class="field-picker">{{form.businessHours}}</view>
          </picker>
        </view>
      </view>

      <!-- 地址 -->
      <view class="form-block">
        <view class="form-block-title">门店地址</view>
        <view class="form-field">
          <view class="field-label">详细地址</view>
          <view class="field-control field-control--tap" bindtap="chooseLocation">
            <text wx:if="{{form.address}}">{{form.address}}</text>
            <text wx:else class="field-placeholder">点击选择门店位置</text>
          </view>
        </view>
        <view class="form-field">
          <view class="field-label">省市区</view>
          <picker mode="region" value="{{[form.province, form.city, form.district]}}" bindchange="fillRegion">
            <view class="field-picker">
              <text wx:if="{{form.province}}">{{form.province}} {{form.city}} {{form.district}}</text>
              <text wx:else class="field-placeholder">选择省市区</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 联系人 -->
      <view class="form-block">
        <view class="form-block-title">联系人信息</view>
        <view class="form-field">
          <view class="field-label">申请人姓名</view>
          <input class="field-control" placeholder-class="field-placeholder" placeholder="门店负责人" data-field="applicantName" value="{{form.applicantName}}" bindinput="handleInput" />
        </view>
        <view class="form-field">
          <view class="field-label">手机号</view>
          <input class="field-control" type="number" maxlength="11" placeholder-class="field-placeholder" placeholder="用于接收审核通知" data-field="phone" value="{{form.phone}}" bindinput="handleInput" />
        </view>
        <view class="form-field">
          <view class="field-label">门店联系电话</view>
          <input class="field-control" type="number" placeholder-class="field-placeholder" placeholder="顾客可见的联系电话" data-field="contactPhone" value="{{form.contactPhone}}" bindinput="handleInput" />
        </view>
      </view>

      <view class="submit-section">
        <button class="primary-button" bindtap="submitApplication" loading="{{submitting}}">提交入驻申请</button>
      </view>
    </view>
  </block>
</view>
