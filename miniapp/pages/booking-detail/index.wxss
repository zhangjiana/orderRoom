.detail-hero {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(156, 107, 54, 0.14);
  background: linear-gradient(180deg, #fff8ef 0%, #f8efe3 100%);
}

.detail-title {
  margin-top: 4rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b241d;
}

.detail-subtitle {
  margin: 10rpx 0 18rpx;
  font-size: 26rpx;
  color: #6f6052;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(142, 123, 102, 0.12);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8a7b6d;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 27rpx;
  line-height: 1.5;
  color: #2f2b27;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  flex: 1;
}
