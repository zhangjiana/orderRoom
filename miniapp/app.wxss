page {
  background: #f5efe7;
  color: #2b241d;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 64rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7f2eb 0%, #f2ebe2 40%, #f6f1ea 100%);
}

/* Card base */
.section-card,
.form-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  border: 1rpx solid rgba(98, 76, 52, 0.08);
  background: linear-gradient(180deg, #fffdfa 0%, #faf5ee 100%);
  box-shadow: 0 12rpx 32rpx rgba(80, 56, 31, 0.06);
  box-sizing: border-box;
  padding: 28rpx;
}

/* Tags & Pills */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  line-height: 1;
  background: #efe3d2;
  color: #825f3c;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.status-available,
.status-confirmed,
.status-arrived,
.status-done {
  background: #e7f4eb;
  color: #2d7c4e;
}

.status-warm,
.status-pending {
  background: #fff1df;
  color: #b97926;
}

.status-busy {
  background: #fde8e2;
  color: #bb5a43;
}

.status-cancelled {
  background: #f0ece8;
  color: #8b7e71;
}

/* Buttons */
.primary-button {
  border-radius: 22rpx;
  font-size: 28rpx;
  line-height: 1;
  padding: 26rpx 0;
  font-weight: 600;
  background: linear-gradient(135deg, #b68148 0%, #8e5d2a 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(142, 93, 42, 0.18);
}

.primary-button::after {
  border: none;
}

/* Form */
.form-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2b241d;
}

.form-block {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(142, 123, 102, 0.12);
}

.form-block-title {
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #302821;
}

.form-field {
  margin-top: 20rpx;
}

.field-row {
  display: flex;
  flex-wrap: wrap;
  margin: 20rpx -8rpx 0;
}

.field-col {
  width: calc(50% - 16rpx);
  margin: 0 8rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #3d3730;
}

.field-control,
.field-picker,
.field-textarea {
  display: block;
  width: 100%;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(160, 136, 112, 0.16);
  background: #fffdfa;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.45;
  color: #2f2b27;
}

.field-control,
.field-picker {
  min-height: 88rpx;
}

.field-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-placeholder {
  color: #ad9f90;
}

.field-textarea {
  min-height: 160rpx;
  line-height: 1.7;
}

/* Empty state */
.empty-card {
  padding: 44rpx 28rpx;
  text-align: center;
  border-radius: 24rpx;
  border: 1rpx dashed rgba(149, 121, 91, 0.28);
  background: rgba(255, 253, 249, 0.76);
  color: #8a7b6d;
  font-size: 26rpx;
}

/* Safe area */
.safe-bottom {
  height: 24rpx;
}

/* Shared components */
.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-kicker {
  letter-spacing: 0.2em;
  font-size: 22rpx;
  font-weight: 600;
  text-transform: uppercase;
  color: #9c6b36;
  margin-bottom: 6rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2b241d;
}

/* Banner card */
.banner-card {
  margin-bottom: 20rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2b241d;
  margin-top: 4rpx;
}

.banner-copy {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #5e5246;
  line-height: 1.6;
}

.helper-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a7b6d;
  line-height: 1.6;
}

.banner-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.banner-stat {
  flex: 1;
  text-align: center;
  padding: 18rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(156, 107, 54, 0.06);
}

.banner-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #8e5d2a;
}

.banner-stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a7b6d;
}

/* Buttons */
.secondary-button {
  border-radius: 22rpx;
  font-size: 28rpx;
  line-height: 1;
  padding: 24rpx 0;
  font-weight: 600;
  background: transparent;
  color: #8e5d2a;
  border: 1rpx solid #dbcbb8;
}

.secondary-button::after {
  border: none;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.button-flex {
  flex: 1;
}

/* Filter row */
.filter-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

/* Booking card (shared) */
.booking-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(98, 76, 52, 0.08);
  background: linear-gradient(180deg, #fffdfa 0%, #faf5ee 100%);
  box-shadow: 0 10rpx 28rpx rgba(80, 56, 31, 0.06);
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.ghost-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8a7b6d;
  background: rgba(142, 123, 102, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #29241e;
}

.card-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6f6052;
}

.meta-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.meta-item {
  flex: 1;
}

.meta-label {
  font-size: 22rpx;
  color: #8a7b6d;
}

.meta-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #3d3730;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}
